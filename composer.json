{
    "name": "ziggurat/core-api",
    "description": "High-performance API Gateway for CRM v2.0",
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true,
            "yiisoft/config": true
        }
    },
    "require": {
        "php": ">=8.4",
        "guzzlehttp/guzzle": "^7.9",
        "nyholm/psr7": "^1.8",
        "spiral/roadrunner-http": "^3.3",
        "symfony/http-client": "^8.0",
        "vlucas/phpdotenv": "^5.6",
        "yiisoft/config": "^1.6",
        "yiisoft/di": "^1.4",
        "yiisoft/hydrator": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "extra": {
        "config-plugin-options": {
            "source-directory": "src/config"
        },
        "config-plugin": {
            "common": "src/config/common/*.php",
            "web": "src/config/web/*.php",
            "params": "src/config/params.php"
        }
    }
}
